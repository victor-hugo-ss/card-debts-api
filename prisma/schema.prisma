generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  FRIEND
}

enum InstallmentStatus {
  PENDING
  PAID
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(FRIEND)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  creditCards     CreditCard[]
  ownedPurchases  Purchase[]   @relation("PurchaseOwner")
  friendPurchases Purchase[]   @relation("PurchaseFriend")

  @@map("users")
}

model CreditCard {
  id         String   @id @default(uuid())
  name       String
  brand      String?
  lastDigits String?
  limit      Decimal?
  closingDay Int
  dueDay     Int
  ownerId    String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  purchases Purchase[]
  owner     User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@map("credit_cards")
}

model Purchase {
  id                String   @id @default(uuid())
  description       String
  amount            Decimal
  purchaseDate      DateTime
  installmentsCount Int

  ownerId      String
  friendId     String
  creditCardId String

  owner      User       @relation("PurchaseOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  friend     User       @relation("PurchaseFriend", fields: [friendId], references: [id], onDelete: Cascade)
  creditCard CreditCard @relation(fields: [creditCardId], references: [id], onDelete: Cascade)

  installments Installment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("purchases")
}

model Installment {
  id      String            @id @default(uuid())
  number  Int
  amount  Decimal
  dueDate DateTime
  status  InstallmentStatus @default(PENDING)
  paidAt  DateTime?

  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("installments")
}



